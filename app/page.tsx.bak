"use client";

import { useEffect, useMemo, useState } from "react";
import {
  AgeBand,
  Chore,
  defaultLessons,
  GameState,
  Lesson,
  levelFromXp,
  petStageFromXp,
  STAGE_EMOJI,
  todayStr,
  totalCoins,
  xpToNextLevel,
} from "@/lib/game";
import { clearState, loadState, newGame, saveState } from "@/lib/storage";

const MOCHI = "🐶";
const MOCHI_LINES = [
  "Hi friend! Ready to earn some coins today?",
  "Welcome back! Coinwood is happy to see you.",
  "Let's do something awesome today.",
  "Every coin you earn is a step closer to your goal!",
  "I'm so glad you're here today!",
];

type Tab = "home" | "chores" | "jars" | "lessons" | "goal";

export default function Page() {
  const [state, setState] = useState<GameState | null>(null);
  const [loaded, setLoaded] = useState(false);
  const [tab, setTab] = useState<Tab>("home");
  const [confetti, setConfetti] = useState(false);
  const [activeLesson, setActiveLesson] = useState<Lesson | null>(null);

  useEffect(() => {
    setState(loadState());
    setLoaded(true);
  }, []);

  useEffect(() => {
    if (state) {
      // streak update on date change
      const today = todayStr();
      if (state.lastPlayDate !== today) {
        const last = new Date(state.lastPlayDate);
        const cur = new Date(today);
        const diffDays = Math.round((cur.getTime() - last.getTime()) / 86400000);
        const next = {
          ...state,
          lastPlayDate: today,
          streakDays: diffDays === 1 ? state.streakDays + 1 : 1,
        };
        setState(next);
      }
      saveState(state);
    }
  }, [state]);

  if (!loaded) return null;
  if (!state) return <Onboarding onStart={(s) => setState(s)} />;

  const greeting = MOCHI_LINES[Math.floor((state.xp + state.streakDays) % MOCHI_LINES.length)];
  const lessons = defaultLessons().filter((l) => l.ageBand === state.ageBand || ageBandRank(l.ageBand) <= ageBandRank(state.ageBand));

  function fireConfetti() {
    setConfetti(true);
    setTimeout(() => setConfetti(false), 1300);
  }

  function completeChore(c: Chore) {
    if (!state) return;
    const newChores = state.chores.map((x) => (x.id === c.id ? { ...x, done: true } : x));
    setState({
      ...state,
      chores: newChores,
      xp: state.xp + c.coins,
      jars: {
        ...state.jars,
        spend: state.jars.spend + c.coins, // default to spend; user can re-allocate in Jars tab
      },
    });
    fireConfetti();
  }

  function moveCoins(from: "spend" | "save" | "give", to: "spend" | "save" | "give", amount: number) {
    if (!state || from === to) return;
    if (state.jars[from] < amount) return;
    setState({
      ...state,
      jars: { ...state.jars, [from]: state.jars[from] - amount, [to]: state.jars[to] + amount },
    });
  }

  function setGoal(name: string, emoji: string, target: number) {
    if (!state) return;
    setState({ ...state, goal: { name, target, emoji } });
  }

  function completeLesson(lesson: Lesson, allCorrect: boolean) {
    if (!state) return;
    if (state.lessonsCompleted.includes(lesson.id)) return;
    if (allCorrect) {
      setState({
        ...state,
        xp: state.xp + 30,
        jars: { ...state.jars, spend: state.jars.spend + 10 },
        lessonsCompleted: [...state.lessonsCompleted, lesson.id],
        badges: [...state.badges, lesson.badge],
      });
      fireConfetti();
    }
  }

  const lvl = levelFromXp(state.xp);
  const xpInfo = xpToNextLevel(state.xp);
  const stage = petStageFromXp(state.xp);
  const total = totalCoins(state);

  return (
    <div className="max-w-md mx-auto px-4 pt-6 pb-32 relative">
      <Confetti show={confetti} />

      <header className="card mb-4 flex items-center gap-3">
        <div className="text-5xl float">{MOCHI}</div>
        <div className="flex-1">
          <div className="text-xs text-coal/60 font-bold uppercase tracking-wider">Mayor Mochi says</div>
          <div className="text-sm leading-snug">{greeting}</div>
        </div>
      </header>

      {/* HUD */}
      <section className="card mb-4">
        <div className="flex items-center gap-3">
          <div className="text-5xl">{STAGE_EMOJI[stage]}</div>
          <div className="flex-1">
            <div className="display text-lg leading-tight">{state.kidName}</div>
            <div className="text-xs text-coal/60">
              {state.petName} · Level {lvl} · {state.ageBand}
            </div>
            <div className="mt-1 h-2 bg-coal/10 rounded-full overflow-hidden">
              <div
                className="h-full bg-sky-deep transition-all"
                style={{ width: `${xpInfo.pct}%` }}
              />
            </div>
            <div className="text-[10px] text-coal/50 mt-0.5">
              {xpInfo.current}/{xpInfo.needed} XP to next level
            </div>
          </div>
          <div className="text-center">
            <div className="text-2xl">🔥</div>
            <div className="text-xs font-bold">{state.streakDays}d</div>
          </div>
        </div>
        <div className="grid grid-cols-3 gap-2 mt-3 text-center">
          <Stat label="Total" value={`🪙 ${total}`} />
          <Stat label="Lessons" value={`📘 ${state.lessonsCompleted.length}`} />
          <Stat label="Badges" value={`🏅 ${state.badges.length}`} />
        </div>
      </section>

      {tab === "home" && (
        <Home
          state={state}
          lessons={lessons}
          onPickTab={setTab}
          onOpenLesson={setActiveLesson}
        />
      )}
      {tab === "chores" && <Chores state={state} onComplete={completeChore} onResetDaily={() => setState({ ...state, chores: state.chores.map((c) => ({ ...c, done: false })) })} />}
      {tab === "jars" && <Jars state={state} onMove={moveCoins} />}
      {tab === "lessons" && <Lessons state={state} lessons={lessons} onOpen={setActiveLesson} />}
      {tab === "goal" && <Goal state={state} onSet={setGoal} />}

      {activeLesson && (
        <LessonModal
          lesson={activeLesson}
          done={state.lessonsCompleted.includes(activeLesson.id)}
          onClose={() => setActiveLesson(null)}
          onComplete={(ok) => {
            completeLesson(activeLesson, ok);
            setActiveLesson(null);
          }}
        />
      )}

      <nav className="fixed bottom-0 inset-x-0 mx-auto max-w-md bg-cream border-t-4 border-white shadow-2xl">
        <div className="grid grid-cols-5 text-center">
          {(["home", "chores", "jars", "lessons", "goal"] as Tab[]).map((t) => (
            <button
              key={t}
              onClick={() => setTab(t)}
              className={`py-3 text-2xl ${tab === t ? "bg-sky-soft" : ""}`}
              aria-label={t}
            >
              {t === "home" && "🏠"}
              {t === "chores" && "✅"}
              {t === "jars" && "🫙"}
              {t === "lessons" && "📘"}
              {t === "goal" && "🎯"}
              <div className="text-[10px] capitalize font-bold">{t}</div>
            </button>
          ))}
        </div>
      </nav>

      <button
        className="fixed top-2 right-2 text-xs text-coal/40 underline"
        onClick={() => {
          if (confirm("Reset everything?")) {
            clearState();
            setState(null);
          }
        }}
      >
        reset
      </button>
    </div>
  );
}

function ageBandRank(a: AgeBand): number {
  return a === "4-7" ? 1 : a === "8-12" ? 2 : 3;
}

function Stat({ label, value }: { label: string; value: string }) {
  return (
    <div className="bg-white/60 rounded-xl py-1.5">
      <div className="text-sm font-bold display">{value}</div>
      <div className="text-[10px] text-coal/60">{label}</div>
    </div>
  );
}

function Onboarding({ onStart }: { onStart: (s: GameState) => void }) {
  const [name, setName] = useState("");
  const [pet, setPet] = useState("Bunny Bo");
  const [age, setAge] = useState<AgeBand>("8-12");
  return (
    <div className="max-w-md mx-auto px-6 pt-12">
      <div className="text-center mb-6">
        <div className="text-6xl mb-3 wiggle">🐶</div>
        <h1 className="display text-3xl mb-2">Welcome to Coinwood!</h1>
        <p className="text-sm text-coal/70">
          I&apos;m Mayor Mochi. Let&apos;s build your home in our town and earn your first coins.
        </p>
      </div>
      <div className="card space-y-4">
        <label className="block">
          <div className="text-xs font-bold uppercase tracking-wider mb-1">Your name</div>
          <input
            value={name}
            onChange={(e) => setName(e.target.value)}
            placeholder="Type your name"
            className="w-full px-4 py-3 rounded-xl border-2 border-coal/20 bg-white focus:outline-none focus:border-sky-deep"
          />
        </label>
        <label className="block">
          <div className="text-xs font-bold uppercase tracking-wider mb-1">Your age</div>
          <div className="grid grid-cols-3 gap-2">
            {(["4-7", "8-12", "13-18"] as AgeBand[]).map((a) => (
              <button
                key={a}
                onClick={() => setAge(a)}
                className={`py-2 rounded-xl font-bold ${
                  age === a ? "bg-sky-deep text-white" : "bg-white border-2 border-coal/10"
                }`}
              >
                {a}
              </button>
            ))}
          </div>
        </label>
        <label className="block">
          <div className="text-xs font-bold uppercase tracking-wider mb-1">Pet name</div>
          <input
            value={pet}
            onChange={(e) => setPet(e.target.value)}
            className="w-full px-4 py-3 rounded-xl border-2 border-coal/20 bg-white focus:outline-none focus:border-sky-deep"
          />
        </label>
        <button
          disabled={!name.trim()}
          onClick={() => onStart(newGame(name.trim(), age, pet.trim() || "Bo"))}
          className="btn-fun w-full justify-center text-lg"
        >
          Start adventure 🚀
        </button>
      </div>
    </div>
  );
}

function Home({
  state,
  lessons,
  onPickTab,
  onOpenLesson,
}: {
  state: GameState;
  lessons: Lesson[];
  onPickTab: (t: Tab) => void;
  onOpenLesson: (l: Lesson) => void;
}) {
  const undone = state.chores.filter((c) => !c.done && (c.ageBand === state.ageBand || ageBandRank(c.ageBand) <= ageBandRank(state.ageBand))).slice(0, 2);
  const nextLesson = lessons.find((l) => !state.lessonsCompleted.includes(l.id));
  return (
    <div className="space-y-3">
      <div className="card">
        <div className="display text-base mb-2">🌟 Today&apos;s Quests</div>
        {undone.length === 0 ? (
          <div className="text-sm text-coal/60 italic">All done! Tap ✅ to reset for tomorrow.</div>
        ) : (
          undone.map((c) => (
            <div key={c.id} className="flex items-center gap-3 py-2 border-b border-coal/5 last:border-none">
              <div className="text-3xl">{c.emoji}</div>
              <div className="flex-1">
                <div className="font-bold text-sm">{c.title}</div>
                <div className="text-xs text-coal/60">🪙 +{c.coins} coins</div>
              </div>
              <button onClick={() => onPickTab("chores")} className="text-xs btn-fun !py-1.5 !px-3">
                Do it
              </button>
            </div>
          ))
        )}
      </div>

      {nextLesson && (
        <div className="card">
          <div className="display text-base mb-2">📘 Next Lesson</div>
          <div className="flex items-center gap-3">
            <div className="text-4xl">{nextLesson.emoji}</div>
            <div className="flex-1">
              <div className="font-bold text-sm">{nextLesson.title}</div>
              <div className="text-xs text-coal/60">{nextLesson.mentor} · 5 min · 🪙 +10 + 30 XP</div>
            </div>
            <button onClick={() => onOpenLesson(nextLesson)} className="text-xs btn-pink !py-1.5 !px-3">
              Learn
            </button>
          </div>
        </div>
      )}

      {state.goal && (
        <div className="card">
          <div className="display text-base mb-2">🎯 Goal</div>
          <div className="flex items-center gap-3">
            <div className="text-4xl">{state.goal.emoji}</div>
            <div className="flex-1">
              <div className="font-bold text-sm">{state.goal.name}</div>
              <div className="text-xs text-coal/60">
                🪙 {state.jars.save} of {state.goal.target}
              </div>
              <div className="mt-1 h-2 bg-coal/10 rounded-full overflow-hidden">
                <div
                  className="h-full bg-mint-deep"
                  style={{ width: `${Math.min(100, (state.jars.save / state.goal.target) * 100)}%` }}
                />
              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );
}

function Chores({
  state,
  onComplete,
  onResetDaily,
}: {
  state: GameState;
  onComplete: (c: Chore) => void;
  onResetDaily: () => void;
}) {
  const eligible = state.chores.filter((c) => ageBandRank(c.ageBand) <= ageBandRank(state.ageBand));
  return (
    <div className="card">
      <div className="flex items-center justify-between mb-2">
        <div className="display text-base">✅ Chores</div>
        <button onClick={onResetDaily} className="text-xs underline text-coal/60">
          Reset for tomorrow
        </button>
      </div>
      {eligible.map((c) => (
        <div key={c.id} className="flex items-center gap-3 py-2 border-b border-coal/5 last:border-none">
          <div className="text-3xl">{c.emoji}</div>
          <div className="flex-1">
            <div className={`font-bold text-sm ${c.done ? "line-through text-coal/40" : ""}`}>{c.title}</div>
            <div className="text-xs text-coal/60">🪙 +{c.coins}</div>
          </div>
          {c.done ? (
            <span className="text-2xl">✨</span>
          ) : (
            <button onClick={() => onComplete(c)} className="btn-mint text-xs !py-1.5 !px-3">
              Done!
            </button>
          )}
        </div>
      ))}
    </div>
  );
}

function Jars({
  state,
  onMove,
}: {
  state: GameState;
  onMove: (from: "spend" | "save" | "give", to: "spend" | "save" | "give", amount: number) => void;
}) {
  return (
    <div className="space-y-3">
      <div className="card">
        <div className="display text-base mb-3">🫙 Your Jars</div>
        <div className="grid grid-cols-3 gap-2 text-center">
          <JarView label="Save" color="var(--color-mint-deep)" amount={state.jars.save} max={Math.max(50, totalCoins(state))} />
          <JarView label="Spend" color="var(--color-pink-deep)" amount={state.jars.spend} max={Math.max(50, totalCoins(state))} />
          <JarView label="Give" color="var(--color-yellow-deep)" amount={state.jars.give} max={Math.max(50, totalCoins(state))} />
        </div>
      </div>
      <div className="card">
        <div className="display text-base mb-2">Move coins</div>
        <div className="text-xs text-coal/60 mb-3">
          Coins start in Spend. Move some to Save (for goals!) or Give (to help others).
        </div>
        <MoveControls state={state} onMove={onMove} />
      </div>
    </div>
  );
}

function MoveControls({
  state,
  onMove,
}: {
  state: GameState;
  onMove: (from: "spend" | "save" | "give", to: "spend" | "save" | "give", amount: number) => void;
}) {
  const [amt, setAmt] = useState(5);
  return (
    <>
      <div className="flex gap-2 items-center mb-3">
        <span className="text-xs font-bold">Amount:</span>
        {[1, 5, 10, 20].map((n) => (
          <button
            key={n}
            onClick={() => setAmt(n)}
            className={`px-3 py-1 rounded-full text-sm font-bold ${
              amt === n ? "bg-sky-deep text-white" : "bg-white border border-coal/20"
            }`}
          >
            {n}
          </button>
        ))}
      </div>
      <div className="space-y-2">
        <button
          disabled={state.jars.spend < amt}
          onClick={() => onMove("spend", "save", amt)}
          className="btn-mint w-full justify-center text-sm"
        >
          Spend → Save 🪙{amt}
        </button>
        <button
          disabled={state.jars.spend < amt}
          onClick={() => onMove("spend", "give", amt)}
          className="btn-yellow w-full justify-center text-sm"
        >
          Spend → Give 🪙{amt}
        </button>
        <button
          disabled={state.jars.save < amt}
          onClick={() => onMove("save", "spend", amt)}
          className="btn-pink w-full justify-center text-sm"
        >
          Save → Spend 🪙{amt}
        </button>
      </div>
    </>
  );
}

function JarView({ label, color, amount, max }: { label: string; color: string; amount: number; max: number }) {
  const pct = Math.min(100, (amount / max) * 100);
  return (
    <div>
      <div className="jar">
        <div className="jar-fill" style={{ height: `${pct}%`, background: color }} />
        <div className="absolute inset-0 flex items-center justify-center display font-bold text-coal text-lg">
          🪙{amount}
        </div>
      </div>
      <div className="display text-xs mt-2 font-bold">{label}</div>
    </div>
  );
}

function Lessons({
  state,
  lessons,
  onOpen,
}: {
  state: GameState;
  lessons: Lesson[];
  onOpen: (l: Lesson) => void;
}) {
  return (
    <div className="card">
      <div className="display text-base mb-2">📘 Lessons</div>
      {lessons.map((l) => {
        const done = state.lessonsCompleted.includes(l.id);
        return (
          <div key={l.id} className="flex items-center gap-3 py-2 border-b border-coal/5 last:border-none">
            <div className="text-3xl">{l.emoji}</div>
            <div className="flex-1">
              <div className={`font-bold text-sm ${done ? "text-coal/40" : ""}`}>{l.title}</div>
              <div className="text-xs text-coal/60">
                {l.mentor} · {l.ageBand}
              </div>
            </div>
            <button onClick={() => onOpen(l)} className={`text-xs ${done ? "" : "btn-pink"} !py-1.5 !px-3`}>
              {done ? "✅" : "Start"}
            </button>
          </div>
        );
      })}
    </div>
  );
}

function LessonModal({
  lesson,
  done,
  onClose,
  onComplete,
}: {
  lesson: Lesson;
  done: boolean;
  onClose: () => void;
  onComplete: (allCorrect: boolean) => void;
}) {
  const [step, setStep] = useState<"intro" | "quiz" | "result">("intro");
  const [picks, setPicks] = useState<number[]>([]);
  const [showWhy, setShowWhy] = useState<number | null>(null);

  const score = useMemo(
    () => picks.reduce((acc, p, i) => acc + (p === lesson.quiz[i]?.correct ? 1 : 0), 0),
    [picks, lesson]
  );
  const allCorrect = score === lesson.quiz.length;

  return (
    <div className="fixed inset-0 bg-coal/40 flex items-end sm:items-center justify-center z-50 p-4">
      <div className="bg-cream rounded-3xl p-5 max-w-md w-full max-h-[85vh] overflow-y-auto">
        <button onClick={onClose} className="float-right text-coal/40 text-2xl leading-none">
          ×
        </button>
        <div className="text-5xl mb-2">{lesson.emoji}</div>
        <div className="display text-xl mb-1">{lesson.title}</div>
        <div className="text-xs text-coal/60 mb-3">{lesson.mentor}</div>

        {step === "intro" && (
          <>
            <div className="card !bg-white mb-4 text-sm leading-relaxed">{lesson.blurb}</div>
            {done ? (
              <div className="text-center text-sm text-coal/60">You already earned this badge! 🎉</div>
            ) : (
              <button onClick={() => setStep("quiz")} className="btn-fun w-full justify-center">
                Take the quiz →
              </button>
            )}
          </>
        )}

        {step === "quiz" && (
          <>
            {lesson.quiz.map((q, i) => (
              <div key={i} className="card !bg-white mb-3">
                <div className="font-bold text-sm mb-2">
                  {i + 1}. {q.q}
                </div>
                <div className="space-y-2">
                  {q.options.map((opt, oi) => {
                    const picked = picks[i] === oi;
                    const correct = oi === q.correct;
                    const showResult = picks[i] !== undefined;
                    return (
                      <button
                        key={oi}
                        disabled={showResult}
                        onClick={() => {
                          const next = [...picks];
                          next[i] = oi;
                          setPicks(next);
                          setShowWhy(i);
                        }}
                        className={`w-full text-left text-sm py-2 px-3 rounded-xl border-2 ${
                          showResult
                            ? correct
                              ? "bg-mint-soft border-mint-deep"
                              : picked
                              ? "bg-pink-soft border-pink-deep"
                              : "border-coal/10 opacity-60"
                            : "border-coal/10 hover:border-sky-deep bg-white"
                        }`}
                      >
                        {opt} {showResult && correct && "✅"} {showResult && picked && !correct && "❌"}
                      </button>
                    );
                  })}
                </div>
                {showWhy === i && picks[i] !== undefined && (
                  <div className="mt-2 text-xs italic text-coal/70">💡 {q.why}</div>
                )}
              </div>
            ))}
            {picks.length === lesson.quiz.length && picks.every((p) => p !== undefined) && (
              <button
                onClick={() => {
                  setStep("result");
                  if (!done) onComplete(allCorrect);
                }}
                className="btn-fun w-full justify-center"
              >
                Finish lesson →
              </button>
            )}
          </>
        )}

        {step === "result" && (
          <div className="text-center py-6">
            <div className="text-6xl mb-3">{allCorrect ? "🎉" : "💪"}</div>
            <div className="display text-2xl mb-2">
              {allCorrect ? "You aced it!" : `${score} / ${lesson.quiz.length}`}
            </div>
            {allCorrect && (
              <div className="text-sm text-coal/70 mb-4">
                You earned <strong>{lesson.badge}</strong> + 30 XP + 🪙10 coins!
              </div>
            )}
            <button onClick={onClose} className="btn-fun">
              Back to Coinwood
            </button>
          </div>
        )}
      </div>
    </div>
  );
}

const GOAL_PRESETS = [
  { name: "Lego set", emoji: "🧱", target: 50 },
  { name: "New book", emoji: "📚", target: 20 },
  { name: "Video game", emoji: "🎮", target: 80 },
  { name: "Skateboard", emoji: "🛹", target: 100 },
  { name: "Stuffed animal", emoji: "🧸", target: 30 },
];

function Goal({ state, onSet }: { state: GameState; onSet: (n: string, e: string, t: number) => void }) {
  const [name, setName] = useState("");
  const [emoji, setEmoji] = useState("🎁");
  const [target, setTarget] = useState(50);
  return (
    <div className="card">
      <div className="display text-base mb-2">🎯 Set a Savings Goal</div>
      {state.goal && (
        <div className="bg-mint-soft rounded-xl p-3 mb-3">
          <div className="font-bold text-sm">
            Current: {state.goal.emoji} {state.goal.name}
          </div>
          <div className="text-xs">
            🪙 {state.jars.save} / {state.goal.target} saved
          </div>
        </div>
      )}
      <div className="text-xs text-coal/60 mb-2">Pick something fun to save for:</div>
      <div className="grid grid-cols-2 gap-2 mb-3">
        {GOAL_PRESETS.map((g) => (
          <button
            key={g.name}
            onClick={() => onSet(g.name, g.emoji, g.target)}
            className="card !p-3 text-left hover:bg-sky-soft transition-colors"
          >
            <div className="text-2xl">{g.emoji}</div>
            <div className="font-bold text-sm">{g.name}</div>
            <div className="text-xs text-coal/60">🪙 {g.target}</div>
          </button>
        ))}
      </div>
      <div className="text-xs font-bold uppercase tracking-wider mb-1">Or pick your own:</div>
      <div className="flex gap-2 mb-2">
        <input
          value={emoji}
          onChange={(e) => setEmoji(e.target.value)}
          className="w-14 px-2 py-2 rounded-xl border-2 border-coal/10 text-center text-xl"
        />
        <input
          value={name}
          onChange={(e) => setName(e.target.value)}
          placeholder="What do you want?"
          className="flex-1 px-3 py-2 rounded-xl border-2 border-coal/10"
        />
        <input
          type="number"
          value={target}
          onChange={(e) => setTarget(parseInt(e.target.value) || 10)}
          className="w-20 px-2 py-2 rounded-xl border-2 border-coal/10"
        />
      </div>
      <button
        disabled={!name.trim()}
        onClick={() => {
          onSet(name.trim(), emoji, target);
          setName("");
        }}
        className="btn-mint w-full justify-center"
      >
        Set goal 🎯
      </button>
    </div>
  );
}

function Confetti({ show }: { show: boolean }) {
  if (!show) return null;
  const pieces = Array.from({ length: 24 });
  return (
    <div className="fixed inset-0 pointer-events-none z-40 flex items-center justify-center">
      {pieces.map((_, i) => {
        const angle = (i / pieces.length) * Math.PI * 2;
        const dist = 80 + Math.random() * 120;
        const dx = Math.cos(angle) * dist;
        const dy = Math.sin(angle) * dist;
        const emoji = ["🪙", "✨", "🎉", "⭐", "💫"][i % 5];
        return (
          <span
            key={i}
            className="confetti text-2xl"
            style={
              {
                "--dx": `${dx}px`,
                "--dy": `${dy}px`,
                animationDelay: `${i * 10}ms`,
              } as React.CSSProperties
            }
          >
            {emoji}
          </span>
        );
      })}
    </div>
  );
}
