"use client";

import Link from "next/link";
import { useEffect, useState } from "react";
import { Mochi } from "@/components/characters";
import { GameScene } from "@/components/GameScene";

const PORTALS = [
  {
    href: "/play/coinland",
    title: "COIN LAND",
    sub: "Tap & play",
    age: "4 - 7",
    emoji: "⭐",
    color: "from-[#fbbf24] to-[#d97706]",
    shadow: "shadow-[0_8px_0_0_#92400e]",
    storageKey: "winwinwin.v1",
  },
  {
    href: "/play/village",
    title: "COIN TOWN",
    sub: "Run a stand",
    age: "8 - 12",
    emoji: "🏘️",
    color: "from-[#22c55e] to-[#15803d]",
    shadow: "shadow-[0_8px_0_0_#14532d]",
    storageKey: "winwinwin.village.v1",
  },
  {
    href: "/play/markets",
    title: "MONEY WORLD",
    sub: "Build wealth",
    age: "13 - 18",
    emoji: "📈",
    color: "from-[#3b82f6] to-[#1d4ed8]",
    shadow: "shadow-[0_8px_0_0_#1e3a8a]",
    storageKey: "winwinwin.markets.v1",
  },
];

export default function HomePage() {
  const [hasProgress, setHasProgress] = useState<Record<string, boolean>>({});

  useEffect(() => {
    if (typeof window === "undefined") return;
    setHasProgress({
      "winwinwin.v1": !!localStorage.getItem("winwinwin.v1"),
      "winwinwin.village.v1": !!localStorage.getItem("winwinwin.village.v1"),
      "winwinwin.markets.v1": !!localStorage.getItem("winwinwin.markets.v1"),
    });
  }, []);

  return (
    <div className="relative min-h-screen overflow-hidden">
      <GameScene />

      <div className="relative z-10 max-w-md mx-auto min-h-screen flex flex-col">
        {/* TOP — title bar floating in sky */}
        <div className="text-center pt-6 px-4 pb-2">
          <h1 className="display text-5xl font-black tracking-tight drop-shadow-[0_4px_0_rgba(0,0,0,0.15)]">
            <span className="text-white" style={{ WebkitTextStroke: "3px #1d4ed8" }}>WIN</span>{" "}
            <span className="text-white" style={{ WebkitTextStroke: "3px #16a34a" }}>WIN</span>{" "}
            <span className="text-white" style={{ WebkitTextStroke: "3px #ea580c" }}>WIN</span>
          </h1>
          <div className="display text-base font-bold text-[#1f2937]/70 mt-1">Money games for kids</div>
        </div>

        {/* MIDDLE — Mochi standing on the hill (massive) */}
        <div className="flex-1 flex flex-col items-center justify-end pb-2 relative">
          <div className="absolute top-12 left-1/2 -translate-x-1/2 bg-white border-[3px] border-[#1f2937] rounded-3xl px-4 py-3 shadow-[0_5px_0_0_#1f2937] anim-bounce-in z-10">
            <div className="display text-base font-bold leading-tight whitespace-nowrap">Hi! I&apos;m Mochi! 👋</div>
            <div className="text-sm text-[#1f2937]/80">Pick a world to play! 👇</div>
          </div>
          <div className="w-64 h-72 anim-float mascot-shadow">
            <Mochi className="w-full h-full" mood="wave" />
          </div>
        </div>

        {/* BOTTOM — 3 portal buttons floating */}
        <div className="px-3 pb-6 space-y-3 relative z-10 bg-gradient-to-b from-transparent to-[#16a34a]/30 pt-4">
          {PORTALS.map((p) => {
            const has = hasProgress[p.storageKey];
            return (
              <Link
                key={p.href}
                href={p.href}
                className={`block bg-gradient-to-br ${p.color} ${p.shadow} rounded-3xl p-4 border-[4px] border-white active:translate-y-2 active:shadow-[0_2px_0_0_rgba(0,0,0,0.3)] transition-transform duration-100`}
              >
                <div className="flex items-center gap-3">
                  <div className="text-6xl shrink-0 mascot-shadow anim-float">{p.emoji}</div>
                  <div className="flex-1 min-w-0">
                    <div className="display text-2xl font-black text-white leading-none drop-shadow-[0_2px_0_rgba(0,0,0,0.25)]">
                      {p.title}
                    </div>
                    <div className="text-sm font-bold text-white/95 leading-tight mt-0.5">{p.sub}</div>
                    <div className="display text-[10px] font-bold text-white/70 uppercase tracking-wider mt-0.5">
                      ages {p.age}
                    </div>
                  </div>
                  <div className="text-3xl text-white shrink-0">
                    {has ? "▶" : "▶"}
                  </div>
                </div>
                {has && (
                  <div className="text-xs text-white/90 font-bold display mt-2 text-center">★ Continue your game</div>
                )}
              </Link>
            );
          })}
        </div>

        {/* GROWN-UPS — small footer link */}
        <div className="text-center pb-4 bg-[#16a34a]/30 px-4">
          <Link
            href="/parent"
            className="text-xs text-white/80 underline display font-bold drop-shadow"
          >
            👨‍👩‍👧 Grown-ups
          </Link>
        </div>
      </div>
    </div>
  );
}
